# ─────────────────────────────────────────────────────────────────────────────
# Get Kempt Frontend - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local for local development
# For Cloudflare Pages, set these in the Dashboard under:
#   Pages > your-project > Settings > Environment variables
# ─────────────────────────────────────────────────────────────────────────────

# Which environment this build targets: development | uat | production
NEXT_PUBLIC_APP_ENV=development

# Base path (only needed if deploying to a subdirectory)
NEXT_PUBLIC_BASE_PATH=

# Backend API URL
# Local:      http://localhost:8080
# Dev:        https://api-dev.getkempt.co
# UAT:        https://api-uat.getkempt.co
# Production: https://api.getkempt.co
NEXT_PUBLIC_API_URL=http://localhost:8080

# Google Maps API Key (for store location maps)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
